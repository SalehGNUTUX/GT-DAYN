{
  "name": "gt-dayn",
  "version": "1.0.0",
  "description": "سجل الديون الذكي — GT-DAYN",
  "author": "GT Team",
  "private": true,
  "type": "module",

  "scripts": {
    "dev":              "vite",
    "build":            "vite build",
    "preview":          "vite preview",

    "electron:dev":     "concurrently \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron platforms/electron/main.js\"",
    "electron:build":   "vite build && electron-builder --config electron-builder.json",

    "android:add":      "npx cap add android",
    "android:sync":     "vite build && npx cap sync android",
    "android:open":     "npx cap open android",
    "android:run":      "npm run android:sync && npx cap run android",

    "lint":             "eslint src --ext .js",
    "test":             "vitest run"
  },

  "dependencies": {
    "@capacitor/core":               "^6.0.0",
    "@capacitor/cli":                "^6.0.0",
    "@capacitor-community/sqlite":   "^6.0.0",
    "sql.js":                        "^1.10.3"
  },

  "devDependencies": {
    "vite":              "^5.0.0",
    "vite-plugin-pwa":   "^0.19.0",
    "electron":          "^31.0.0",
    "electron-builder":  "^24.0.0",
    "better-sqlite3":    "^9.0.0",
    "concurrently":      "^8.0.0",
    "wait-on":           "^7.0.0",
    "eslint":            "^8.0.0",
    "vitest":            "^1.0.0"
  }
}
