{
  "appId": "com.gtdayn.app",
  "productName": "GT-DAYN",
  "copyright": "Copyright © 2025 GT Team",
  "directories": {
    "output": "dist-electron",
    "app": "."
  },
  "files": [
    "dist/**/*",
    "platforms/electron/**/*",
    "src/core/db/schema.sql",
    "package.json"
  ],
  "extraResources": [
    { "from": "src/core/db/schema.sql", "to": "schema.sql" }
  ],
  "asar": true,
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "platforms/electron/icons/icon.ico"
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
    "icon": "platforms/electron/icons/icon.icns",
    "category": "public.app-category.finance"
  },
  "linux": {
    "target": [{ "target": "AppImage", "arch": ["x64"] }],
    "icon": "platforms/electron/icons/icon.png",
    "category": "Finance"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "installerLanguages": ["ar", "en"]
  }
}
